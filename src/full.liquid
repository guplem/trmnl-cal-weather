{% comment %}
  TRMNL Calendar + Weather Plugin (Time-Grid Layout)
  Events positioned at actual time slots. Dynamic time range.
  Calendar bars use grayscale + patterns on the stripe for differentiation.
  Past events dimmed. Current time tick on axis.
  Overlapping events displayed side by side.

  Data sources (Polling strategy):
    IDX_0 = TRMNL Calendar API (events grouped by "Month DD" keys)
    IDX_1 = Open-Meteo daily forecast + current conditions

  Recommended Open-Meteo URL (IDX_1):
    https://api.open-meteo.com/v1/forecast?latitude=41.39&longitude=2.17
      &daily=temperature_2m_max,temperature_2m_min,weather_code,precipitation_probability_max,sunrise,sunset,uv_index_max
      &hourly=temperature_2m,precipitation_probability
      &current=temperature_2m
      &timezone=Europe/Madrid&forecast_days=7

  Optional Air Quality URL (IDX_2):
    https://air-quality-api.open-meteo.com/v1/air-quality?latitude=41.39&longitude=2.17&current=european_aqi&timezone=Europe/Madrid
{% endcomment %}

<style>
  * { box-sizing: border-box; }
  .screen, .view, .layout, .layout--col, .layout--row { padding: 0 !important; margin: 0 !important; width: 100% !important; height: 480px !important }
  #cw-container { width: 100%; height: 480px; }

  .cw-wrap {
    width: 100%; height: 480px;
    display: flex; flex-direction: column;
    font-family: -apple-system, 'Helvetica Neue', Arial, sans-serif;
    -webkit-font-smoothing: none; overflow: hidden;
  }

  /* flex alignment rules */
  .cw-corner { justify-content: flex-end; }
  .cw-corner-weather, .cw-weather-cell, .cw-empty { justify-content: center; }
  .cw-wx-text { justify-content: space-between; }

  /* === HEADER === */
  .cw-header-row { display: flex; flex-shrink: 0; }
  .cw-corner {
    width: 34px; flex-shrink: 0;
    display: flex; flex-direction: column;
    align-items: center;
    background: #000; color: #fff; line-height: 1;
  }
  .cw-corner-temp { font: bold 12px sans-serif; }
  .cw-corner-rain { font: 9px sans-serif; }
  .cw-day-headers { flex: 1; display: grid; grid-template-columns: repeat(7, 1fr); }
  .cw-day-header {
    background: #000; color: #fff;
    font: bold 10px/1.2 sans-serif;
    white-space: nowrap; border-left: 1px solid #555;
  }
  .cw-day-header.is-today { background: #555; }

  /* === WEATHER === */
  .cw-weather-row { display: flex; flex-shrink: 0; border-bottom: 1px solid #000; }
  .cw-corner-weather {
    width: 34px; flex-shrink: 0;
    display: flex; align-items: center;
    background: #000; color: #fff;
    border-bottom: 1px solid #000;
  }
  .cw-weather-cell {
    display: flex; align-items: center;
    gap: 2px; min-height: 30px; border-left: 1px solid #AAA;
    position: relative; overflow: hidden;
  }
  .cw-wx-text svg { width: 14px; height: 14px; flex-shrink: 0; }
  .cw-temps { font: 9px sans-serif; white-space: nowrap; letter-spacing: -0.3px; background: #fff; }
  .cw-temp-max { font-weight: bold; }
  .cw-wx-night {
    position: absolute; left: 0; right: 0; top: 0; bottom: 0;
    width: 100%; height: 100%;
    display: flex; z-index: 0;
  }
  .cw-wx-night > div { flex: 1; }
  .cw-wx-night-on {
    background: radial-gradient(#AAA 0.5px, transparent 0.5px) 0 0 / 4px 4px #fff;
  }
  .cw-wx-precip {
    position: absolute; left: 0; right: 0; top: 0; bottom: 0;
    width: 100%; height: 100%;
    display: flex; align-items: flex-end; z-index: 1;
  }
  .cw-wx-precip > div { flex: 1; background: #AAA; min-width: 0; }
  .cw-wx-templine {
    position: absolute; left: 0; right: 0; top: 0; bottom: 0;
    width: 100%; height: 100%; z-index: 2;
  }
  .cw-wx-now {
    position: absolute; top: 0; bottom: 0;
    width: 2px; background: #000; z-index: 4;
  }
  .cw-wx-text {
    position: absolute; top: 1px; left: 1px; right: 1px;
    z-index: 3;
    display: flex; align-items: flex-start;
  }

  /* === ALL-DAY === */
  .cw-allday-row { display: flex; flex-shrink: 0; border-bottom: 1px solid #000; }
  .cw-allday-label { width: 34px; flex-shrink: 0; font: 7px sans-serif; color: #555; border-bottom: 1px solid #000; }
  .cw-allday-cell { overflow: hidden; display: flex; flex-direction: column; gap: 1px; border-left: 1px solid #AAA; }
  .cw-allday-evt { display: flex; align-items: stretch; overflow: hidden; }
  .cw-allday-bar { width: 6px; flex-shrink: 0; }
  .cw-allday-text {
    flex: 1; font: 8px/1.4 sans-serif;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    color: #000; border: 1px solid #AAA; border-left: none;
  }
  .cw-allday-text.is-past { background: #AAA; }
  .cw-allday-text.is-future { background: #fff; }

  /* === TIME GRID === */
  .cw-grid-area { flex: 1; display: flex; overflow: hidden; position: relative; }
  .cw-time-axis { width: 34px; flex-shrink: 0; position: relative; border-right: 1px solid #AAA; }
  .cw-hour-label {
    position: absolute; right: 2px; font: bold 9px sans-serif; color: #555;
    line-height: 1; transform: translateY(-50%); white-space: nowrap;
  }
  .cw-hour-weather {
    position: absolute; right: 1px; font: 8px sans-serif; color: #555;
    line-height: 1; transform: translateY(-50%); white-space: nowrap;
  }
  .cw-now-tick {
    position: absolute; left: 0; right: -1px;
    height: 2px; background: #000;
    transform: translateY(-1px); z-index: 20;
  }
  .cw-now-label {
    position: absolute; left: 1px;
    font: bold 7px/1 sans-serif; color: #000;
    white-space: nowrap;
    transform: translateY(calc(-100% - 2px));
  }
  .cw-columns { flex: 1; display: grid; grid-template-columns: repeat(7, 1fr); position: relative; }
  .cw-day-col { position: relative; border-right: 1px solid #AAA; overflow: hidden; }
  .cw-day-col:last-child { border-right: none; }
  .cw-week-start { position: relative; }
  .cw-week-start::before {
    content: ''; position: absolute; left: 0px; top: 0; bottom: 0;
    width: 2px; background: #555; z-index: 10;
  }
  .cw-hour-line { position: absolute; left: 0; right: 0; height: 0; border-top: 1px dashed #AAA; }
  .cw-half-line { position: absolute; left: 0; right: 0; height: 0; border-top: none; background: repeating-linear-gradient(90deg, #AAA 0px, #AAA 1px, transparent 1px, transparent 7px); height: 1px; }

  /* === EVENTS === */
  .cw-evt {
    position: absolute;
    display: flex; overflow: hidden;
    min-height: 10px; z-index: 5;
  }
  .cw-evt-bar { width: 6px; flex-shrink: 0; }
  .cw-evt-body {
    flex: 1; overflow: hidden;
    min-width: 0; border: 1px solid #AAA; border-left: none;
  }
  .cw-evt-body.is-past { background: #AAA; }
  .cw-evt-body.is-future { background: #fff; }
  .cw-evt-title {
    font: bold 8px/1.2 sans-serif;
    overflow: hidden; word-break: break-word;
  }
  .cw-evt-time { font: 8px/1.1 sans-serif; color: #555; }
  .cw-evt-detail {
    font: 8px/1.1 sans-serif; color: #555;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }

  /* === BAR PATTERNS (11 combos) === */
  .cw-bar-0 { background: #AAA; }
  .cw-bar-1 { background: #000; }
  .cw-bar-2 { background: #fff; border: 1px solid #000; }
  .cw-bar-3 { background: repeating-linear-gradient(45deg, #AAA 0px, #AAA 1.5px, #fff 1.5px, #fff 3px); }
  .cw-bar-4 { background: repeating-linear-gradient(-45deg, #000 0px, #000 1.5px, #fff 1.5px, #fff 3px); }
  .cw-bar-5 { background: repeating-linear-gradient(0deg, #AAA 0px, #AAA 2px, #fff 2px, #fff 4px); }
  .cw-bar-6 { background: repeating-linear-gradient(90deg, #AAA 0px, #AAA 2px, #fff 2px, #fff 4px); }
  .cw-bar-7 { background: repeating-linear-gradient(0deg, #000 0px, #000 2px, #fff 2px, #fff 4px); }
  .cw-bar-8 { background: repeating-linear-gradient(90deg, #000 0px, #000 2px, #fff 2px, #fff 4px); }
  .cw-bar-9 { background: repeating-linear-gradient(-45deg, #AAA 0px, #AAA 1.5px, #fff 1.5px, #fff 3px); }
  .cw-bar-10 { background: repeating-linear-gradient(45deg, #000 0px, #000 1.5px, #fff 1.5px, #fff 3px); }

  /* === LEGEND === */
  .cw-legend {
    display: flex; align-items: center; gap: 8px;
    min-height: 20px;
    flex-shrink: 0; border-top: 1px solid #000;
    font: 8px sans-serif;
  }
  .cw-legend-item { display: flex; align-items: center; gap: 3px; white-space: nowrap; }
  .cw-legend-swatch { width: 6px; height: 12px; flex-shrink: 0; }

  .cw-empty { display: flex; align-items: center; height: 100%; font: 14px sans-serif; color: #555; }

  /* === DIAGNOSTIC OVERLAY === */
  .cw-diag-overlay {
    position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
    z-index: 100; background: #fff; border: 3px solid #000;
    max-width: 600px; width: 90%; max-height: 400px; overflow: auto;
    font: 11px/1.4 monospace; color: #000;
  }
  .cw-diag-title { font: bold 14px sans-serif; background: #000; color: #fff; }
  .cw-diag-item { border-bottom: 1px solid #AAA; }
  .cw-diag-label { font-weight: bold; }
  .cw-diag-raw { font: 9px/1.2 monospace; color: #555; word-break: break-all; max-height: 60px; overflow: hidden; }
</style>

<div id="cw-container" style="width: 100%; height: 100%;"></div>

<script>
document.addEventListener("DOMContentLoaded", function() {
  // Parse data: TRMNL production uses IDX_0/IDX_1, trmnlp uses custom_fields (Ruby hash format)
  // Sanitize raw JSON strings: escape control characters that break JSON.parse
  // (e.g., literal newlines/tabs in calendar event descriptions or locations)
  function sanitizeJson(s) {
    return s.replace(/[\x00-\x1f\x7f]/g, function(c) {
      switch(c) {
        case '\n': return '\\n';
        case '\r': return '\\r';
        case '\t': return '\\t';
        default: return '';
      }
    });
  }
  function parseLiquid(str) { return JSON.parse(sanitizeJson(str.replace(/ => /g, ': '))); }
  function hasCalData(obj) { return obj && typeof obj === 'object' && ((obj.data && obj.data.events) || obj.events); }
  // Deep-parse: handles double-encoded JSON (string inside string) and unwraps nested objects
  function deepParse(raw) {
    if (raw == null) return null;
    // If first parse returned a string, try parsing it again (double-encoded JSON)
    if (typeof raw === 'string') { try { raw = JSON.parse(sanitizeJson(raw)); } catch(e) { return null; } }
    if (typeof raw === 'string') { try { raw = JSON.parse(sanitizeJson(raw)); } catch(e) { return null; } } // triple-encoded edge case
    if (typeof raw !== 'object' || raw === null) return null;
    // If data is at expected path, return as-is
    if (hasCalData(raw)) return raw;
    // Search one level deeper for a wrapper (e.g., { "plugin_setting": { "data": { "events": [...] } } })
    var keys = Object.keys(raw);
    for (var i = 0; i < keys.length; i++) {
      var child = raw[keys[i]];
      if (child && typeof child === 'object' && hasCalData(child)) return child;
    }
    return raw; // return whatever we have; diagnostics will flag it if still bad
  }
  function deepParseWeather(raw) {
    if (raw == null) return null;
    if (typeof raw === 'string') { try { raw = JSON.parse(sanitizeJson(raw)); } catch(e) { return null; } }
    if (typeof raw === 'string') { try { raw = JSON.parse(sanitizeJson(raw)); } catch(e) { return null; } }
    if (typeof raw !== 'object' || raw === null) return null;
    if (raw.daily) return raw;
    var keys = Object.keys(raw);
    for (var i = 0; i < keys.length; i++) {
      var child = raw[keys[i]];
      if (child && typeof child === 'object' && child.daily) return child;
    }
    return raw;
  }
  var calRaw, weatherRaw, diag = [];
  // Calendar: try IDX_0 (production), then custom_fields (trmnlp)
  var calErr = null, calRawType = '';
  try {
    var calParsed = JSON.parse(sanitizeJson(`{{ IDX_0 | json }}`));
    calRawType = typeof calParsed;
    calRaw = deepParse(calParsed);
  } catch(e) { calRaw = null; calErr = e.message; }
  if (!hasCalData(calRaw)) { try { calRaw = deepParse(parseLiquid(`{{ trmnl.plugin_settings.custom_fields_values.IDX_0 }}`)); calErr = null; } catch(e) { if (!calErr) calErr = e.message; } }
  // Weather: try IDX_1 (production + trmnlp polling), then custom_fields
  var wxErr = null;
  try { weatherRaw = deepParseWeather(JSON.parse(sanitizeJson(`{{ IDX_1 | json }}`))); } catch(e) { weatherRaw = null; wxErr = e.message; }
  if (!weatherRaw || !weatherRaw.daily) { try { weatherRaw = deepParseWeather(parseLiquid(`{{ trmnl.plugin_settings.custom_fields_values.IDX_1 }}`)); wxErr = null; } catch(e) { if (!wxErr) wxErr = e.message; } }

  // === DIAGNOSTICS: collect issues for on-screen overlay ===
  function truncate(s, n) { return s.length > n ? s.substring(0, n) + '...' : s; }
  function rawPreview(obj) { try { return truncate(JSON.stringify(obj), 200); } catch(e) { return String(obj).substring(0, 200); } }

  // Calendar diagnostics
  function isTruncationError(err) { return err && /unexpected.*(end|eof)|end of/i.test(err); }
  if (!calRaw) {
    if (isTruncationError(calErr)) {
      diag.push({label: 'Calendar: data truncated', detail: 'The calendar JSON was cut off mid-stream, which means TRMNL\'s data size limit was exceeded. Reduce the number of selected calendars or switch the Google Calendar plugin layout to "Week".'});
    } else if (calErr) {
      var calDetail = 'Parse error: ' + calErr;
      if (calRawType === 'string') calDetail += ' Note: IDX_0 was a string (possible double-encoding).';
      diag.push({label: 'Calendar: bad data received', detail: calDetail});
    } else {
      diag.push({label: 'Calendar: no data received', detail: 'IDX_0 is empty or null. Check that the polling URL and API key are correct.'});
    }
  } else if (calRaw.error) {
    // API returned an error object (e.g., {"error": "Plugin setting not found"})
    var errMsg = calRaw.error;
    var hint = '';
    if (/not found/i.test(errMsg)) hint = 'The Google Calendar plugin ID is wrong. Open your Google Calendar plugin settings and copy the number from the URL: usetrmnl.com/plugin_settings/[THIS_NUMBER]/edit';
    else if (/unauthorized|forbidden|auth/i.test(errMsg)) hint = 'The API key is invalid or expired. Go to trmnl.com/account and copy a fresh API key.';
    else hint = 'Check the polling URL and API key in your plugin settings.';
    diag.push({label: 'Calendar: API error', detail: errMsg + '. ' + hint});
  } else if (!hasCalData(calRaw)) {
    var keys = Object.keys(calRaw);
    var dataKeys = calRaw.data ? Object.keys(calRaw.data) : [];
    diag.push({label: 'Calendar: unexpected format', detail: 'Data received but no "events" array found. Top-level keys: [' + keys.join(', ') + ']' + (dataKeys.length ? '. data.* keys: [' + dataKeys.join(', ') + ']' : ''), raw: rawPreview(calRaw)});
  } else {
    var cd0 = calRaw.data || calRaw;
    var evts0 = cd0.events || [];
    if (Array.isArray(evts0) && evts0.length === 0) {
      diag.push({label: 'Calendar: 0 events', detail: 'The calendar responded but the events array is empty. Verify the Google Calendar plugin has calendars selected and layout set to "Week".'});
    }
  }
  // Weather diagnostics
  if (!weatherRaw && isTruncationError(wxErr)) {
    diag.push({label: 'Weather: data truncated', detail: 'The weather JSON was cut off mid-stream, which means TRMNL\'s data size limit was exceeded. Check the Open-Meteo polling URL.'});
  } else if (!weatherRaw && wxErr) {
    diag.push({label: 'Weather: bad data received', detail: 'Parse error: ' + wxErr});
  } else if (!weatherRaw) {
    diag.push({label: 'Weather: no data received', detail: 'IDX_1 is empty or null. Check the Open-Meteo URL.'});
  } else if (!weatherRaw.daily) {
    diag.push({label: 'Weather: unexpected format', detail: 'Received data but no "daily" object. Keys: [' + Object.keys(weatherRaw).join(', ') + ']', raw: rawPreview(weatherRaw)});
  }

  var container = document.getElementById("cw-container");
  var hasWeather = !!(weatherRaw && weatherRaw.daily);
  // Render diagnostic overlay if issues detected
  function renderDiag() {
    if (diag.length === 0) return '';
    var d = '<div class="cw-diag-overlay"><div class="cw-diag-title p--1">Diagnostic Info</div>';
    for (var i = 0; i < diag.length; i++) {
      d += '<div class="cw-diag-item p--1"><div class="cw-diag-label">' + diag[i].label + '</div>';
      d += '<div>' + diag[i].detail + '</div>';
      if (diag[i].raw) d += '<div class="cw-diag-raw">Raw: ' + diag[i].raw + '</div>';
      d += '</div>';
    }
    d += '</div>';
    return d;
  }

  if (!hasWeather && !hasCalData(calRaw)) {
    container.style.position = 'relative';
    container.innerHTML = '<div class="cw-empty">No data available</div>' + renderDiag();
    return;
  }

  // === PARSE CALENDAR DATA ===
  var eventsByDate = {}, todayStr = "", calFriendlyNames = {}, firstDayOfWeek = 1;
  if (calRaw) {
    var cd = calRaw.data || calRaw;
    var rawEvents = cd.events || [];
    calFriendlyNames = cd.calendar_names || {};
    todayStr = (cd.today_in_tz || "").substring(0, 10);
    firstDayOfWeek = cd.first_day != null ? cd.first_day : 1; // 0=Sun, 1=Mon

    // Handle both flat array (production) and grouped object (trmnlp mock)
    if (Array.isArray(rawEvents)) {
      for (var i = 0; i < rawEvents.length; i++) {
        var ev = rawEvents[i];
        if (ev.all_day) {
          // Multi-day: add to each day in range (end is exclusive)
          var sd = (ev.start_full || ev.start || "").substring(0, 10);
          var ed = (ev.end_full || ev.end || "").substring(0, 10);
          if (sd) {
            var dc = new Date(sd), dce = ed ? new Date(ed) : new Date(sd);
            dce.setDate(dce.getDate()); // end is exclusive for all-day
            while (dc < dce) {
              var dk = dc.getFullYear()+'-'+String(dc.getMonth()+1).padStart(2,'0')+'-'+String(dc.getDate()).padStart(2,'0');
              if (!eventsByDate[dk]) eventsByDate[dk] = [];
              eventsByDate[dk].push(ev);
              dc.setDate(dc.getDate() + 1);
            }
          }
        } else {
          var dk = (ev.date_time || ev.start_full || "").substring(0, 10);
          if (dk) {
            if (!eventsByDate[dk]) eventsByDate[dk] = [];
            eventsByDate[dk].push(ev);
          }
        }
      }
    } else {
      // Grouped by "Month DD" key (trmnlp mock format)
      var MN=["January","February","March","April","May","June","July","August","September","October","November","December"];
      eventsByDate = rawEvents; // already grouped
      // We'll match by calKey below
    }
  }
  var eventsGrouped = Array.isArray((calRaw && (calRaw.data||calRaw).events)||[]);

  // === PARSE WEATHER DATA (all optional) ===
  var daily = hasWeather ? weatherRaw.daily : {};
  var dates = daily.time || [];
  var tempMax = daily.temperature_2m_max || [], tempMin = daily.temperature_2m_min || [];
  var wmoCodes = daily.weather_code || [], rainProb = daily.precipitation_probability_max || [];
  var currentTemp = (hasWeather && weatherRaw.current && weatherRaw.current.temperature_2m != null) ? Math.round(weatherRaw.current.temperature_2m) : null;
  var sunrise = (daily.sunrise && daily.sunrise[0]) ? daily.sunrise[0].substring(11,16) : null;
  var sunset = (daily.sunset && daily.sunset[0]) ? daily.sunset[0].substring(11,16) : null;
  var uvMax = (daily.uv_index_max && daily.uv_index_max[0] != null) ? Math.round(daily.uv_index_max[0]) : null;
  var aqi = null;
  try { var aqRaw = JSON.parse(sanitizeJson(`{{ IDX_2 | json }}`)); if(aqRaw && aqRaw.current) aqi = Math.round(aqRaw.current.european_aqi); } catch(e) {}
  if (aqi===null) { try { var aqRaw2 = parseLiquid(`{{ trmnl.plugin_settings.custom_fields_values.IDX_2 }}`); if(aqRaw2 && aqRaw2.current) aqi = Math.round(aqRaw2.current.european_aqi); } catch(e) {} }

  // If no weather dates, derive from calendar events
  if (dates.length === 0 && todayStr) {
    var d = new Date(todayStr);
    for (var i = 0; i < 7; i++) {
      dates.push(d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0')+'-'+String(d.getDate()).padStart(2,'0'));
      d.setDate(d.getDate() + 1);
    }
  }

  // Hourly weather per date (for charts + axis labels)
  var hourlyByDate = {};
  if (hasWeather && weatherRaw.hourly && weatherRaw.hourly.time) {
    var ht=weatherRaw.hourly.time, hTmp=weatherRaw.hourly.temperature_2m||[], hPrc=weatherRaw.hourly.precipitation_probability||[];
    for(var i=0;i<ht.length;i++){
      var dI=ht[i].substring(0,10), hr=parseInt(ht[i].substring(11,13),10);
      if(!hourlyByDate[dI]) hourlyByDate[dI]=[];
      hourlyByDate[dI][hr]={t:hTmp[i],p:hPrc[i]||0};
    }
  }
  var todayHourly = {};
  var todayH = hourlyByDate[dates[0]]||[];
  for(var hr=0;hr<24;hr++){if(todayH[hr])todayHourly[hr]={t:Math.round(todayH[hr].t),p:Math.round(todayH[hr].p)};}

  // === CALENDAR NAME RESOLUTION ===
  // calFriendlyNames maps email -> display name (e.g. "guplem@gmail.com" -> "Personal")
  function resolveName(email) { return calFriendlyNames[email] || email; }

  var calNameMap = {}, calNameIdx = 0;
  function getCalIdx(cn) { if(!cn)return 0; cn=resolveName(cn); if(calNameMap[cn]===undefined){calNameMap[cn]=calNameIdx%11;calNameIdx++;} return calNameMap[cn]; }

  // Scan all events for unique calendar names
  var allCalNames = [];
  function addCalName(email) {
    var name = resolveName(email);
    if (name && allCalNames.indexOf(name) === -1) allCalNames.push(name);
  }
  for (var dk in eventsByDate) {
    var evs = eventsByDate[dk];
    if (!Array.isArray(evs)) continue;
    for (var e = 0; e < evs.length; e++) addCalName(evs[e].calname || "");
  }
  allCalNames.sort();
  for (var c = 0; c < allCalNames.length; c++) getCalIdx(allCalNames[c]);

  // === HELPERS ===
  var DA=["Sun","Mon","Tue","Wed","Thu","Fri","Sat"];
  var MN2=["January","February","March","April","May","June","July","August","September","October","November","December"];
  function dayInfo(iso){var p=iso.split("-");var d=new Date(+p[0],+p[1]-1,+p[2]);return{dn:DA[d.getDay()],dd:+p[2]};}
  // Parse time from ISO timestamp (e.g. "2026-04-09T08:55:00.000+02:00") or HH:MM or AM/PM
  function toMin(startField, fullField) {
    // Prefer start_full ISO timestamp
    if (fullField && fullField.length > 16) {
      var tp = fullField.substring(11, 16).split(":");
      return +tp[0] * 60 + +tp[1];
    }
    if (!startField) return -1;
    // Handle AM/PM format
    var s = startField.trim().toUpperCase();
    var pm = s.indexOf("PM") > -1, am = s.indexOf("AM") > -1;
    s = s.replace(/[AP]M/gi, "").trim();
    var p = s.split(":");
    var h = +p[0], m = +p[1] || 0;
    if (pm && h < 12) h += 12;
    if (am && h === 12) h = 0;
    return h * 60 + m;
  }
  function esc(s){var d=document.createElement("div");d.appendChild(document.createTextNode(s));return d.innerHTML;}
  function fmtH(m){var h=Math.floor(m/60);return(h<10?" ":"")+h+":00";}
  function fmtT(m){var h=Math.floor(m/60),mm=m%60;return(h<10?"0":"")+h+":"+(mm<10?"0":"")+mm;}
  // Format time for display (from minutes)
  function fmtEvt(m){var h=Math.floor(m/60),mm=m%60;return h+":"+(mm<10?"0":"")+mm;}

  // === GROUP EVENTS BY DATE FOR DISPLAY ===
  // For trmnlp mock data (grouped by "Month DD"), convert keys
  function calKey(iso){var p=iso.split("-");return MN2[+p[1]-1]+" "+p[2];}

  var gMin=1440,gMax=0,hasTimed=false,adByDate={},tmByDate={};
  for(var i=0;i<dates.length&&i<7;i++){
    var de;
    if (eventsGrouped) {
      de = eventsByDate[dates[i]] || []; // ISO key (production)
    } else {
      de = eventsByDate[calKey(dates[i])] || []; // "Month DD" key (trmnlp mock)
    }
    adByDate[dates[i]]=[]; tmByDate[dates[i]]=[];
    for(var j=0;j<de.length;j++){
      var ev=de[j];
      if(ev.all_day){adByDate[dates[i]].push(ev);}
      else{
        var sm=toMin(ev.start, ev.start_full||ev.date_time);
        var em=toMin(ev.end, ev.end_full);
        if(sm<0)continue; if(em<=sm)em=sm+60;
        tmByDate[dates[i]].push({summary:ev.summary||"No title",desc:ev.description||"",loc:ev.location||"",start:fmtEvt(sm),end:fmtEvt(em),sm:sm,em:em,cn:ev.calname||ev.calendar_name||""});
        hasTimed=true; if(sm<gMin)gMin=sm; if(em>gMax)gMax=em;
      }
    }
  }
  if(!hasTimed){gMin=8*60;gMax=18*60;}
  gMin=Math.floor(gMin/60)*60; gMax=Math.ceil(gMax/60)*60;
  if(gMin===gMax)gMax=gMin+60;
  var rng=gMax-gMin;

  var hasAD=false;
  for(var d in adByDate){if(adByDate[d].length>0){hasAD=true;break;}}

  // Use calendar's now_in_tz (user's timezone) if available, otherwise fall back to JS Date (server time)
  var now=new Date();
  var nowMin=now.getHours()*60+now.getMinutes();
  if (calRaw) {
    var cd2 = calRaw.data || calRaw;
    var nowTz = cd2.now_in_tz || "";
    if (nowTz.length >= 16) {
      nowMin = parseInt(nowTz.substring(11,13))*60 + parseInt(nowTz.substring(14,16));
    }
  }
  var todayIso=todayStr||(now.getFullYear()+"-"+String(now.getMonth()+1).padStart(2,"0")+"-"+String(now.getDate()).padStart(2,"0"));

  function isPast(dIso,em){return dIso<todayIso||(dIso===todayIso&&em<=nowMin);}

  // Overlap layout: assign columns to overlapping events
  function layoutOverlaps(evts) {
    evts.sort(function(a,b){return a.sm-b.sm||(b.em-b.sm)-(a.em-a.sm);});
    var clusters=[];
    for(var i=0;i<evts.length;i++){
      var e=evts[i],placed=false;
      for(var ci=0;ci<clusters.length;ci++){
        if(e.sm<clusters[ci].end){clusters[ci].events.push(e);if(e.em>clusters[ci].end)clusters[ci].end=e.em;placed=true;break;}
      }
      if(!placed) clusters.push({end:e.em,events:[e]});
    }
    for(var ci=0;ci<clusters.length;ci++){
      var ce=clusters[ci].events,cols=[];
      for(var i=0;i<ce.length;i++){
        var p=false;
        for(var c=0;c<cols.length;c++){if(ce[i].sm>=cols[c]){cols[c]=ce[i].em;ce[i].col=c;p=true;break;}}
        if(!p){ce[i].col=cols.length;cols.push(ce[i].em);}
      }
      for(var i=0;i<ce.length;i++) ce[i].totalCols=cols.length;
    }
  }

  // Weather icons: SVG with white fill for opaque shapes (cloud, sun circle)
  function wIcon(c){c=+c||0;
    // Clear/sunny: white-filled sun circle + rays
    if(c<=1)return'<svg viewBox="0 0 24 24" fill="none" stroke="#000" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="4" fill="#fff"/><line x1="12" y1="2" x2="12" y2="5"/><line x1="12" y1="19" x2="12" y2="22"/><line x1="5" y1="5" x2="7" y2="7"/><line x1="17" y1="17" x2="19" y2="19"/><line x1="2" y1="12" x2="5" y2="12"/><line x1="19" y1="12" x2="22" y2="12"/><line x1="5" y1="19" x2="7" y2="17"/><line x1="17" y1="7" x2="19" y2="5"/></svg>';
    // Cloudy/overcast: white-filled cloud
    if(c<=3)return'<svg viewBox="0 0 24 24" fill="none" stroke="#000" stroke-width="2" stroke-linecap="round"><path d="M17.5 19H9a7 7 0 1 1 6.7-9h1.8a4.5 4.5 0 0 1 0 9z" fill="#fff"/></svg>';
    // Fog: horizontal lines (no fill needed)
    if(c>=45&&c<=48)return'<svg viewBox="0 0 24 24" fill="none" stroke="#000" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="5" y1="10" x2="19" y2="10"/><line x1="3" y1="14" x2="21" y2="14"/><line x1="5" y1="18" x2="19" y2="18"/></svg>';
    // Drizzle/light showers: white-filled cloud + drops
    if((c>=51&&c<=57)||c===80)return'<svg viewBox="0 0 24 24" fill="none" stroke="#000" stroke-width="2" stroke-linecap="round"><path d="M17.5 17H9a7 7 0 1 1 6.7-9h1.8a4.5 4.5 0 0 1 0 9z" fill="#fff"/><line x1="8" y1="19" x2="7.5" y2="21"/><line x1="13" y1="19" x2="12.5" y2="21"/></svg>';
    // Rain/heavy showers: white-filled cloud + drops
    if((c>=61&&c<=67)||(c>=81&&c<=82))return'<svg viewBox="0 0 24 24" fill="none" stroke="#000" stroke-width="2" stroke-linecap="round"><path d="M17.5 17H9a7 7 0 1 1 6.7-9h1.8a4.5 4.5 0 0 1 0 9z" fill="#fff"/><line x1="7" y1="19" x2="6" y2="22"/><line x1="11" y1="19" x2="10" y2="22"/><line x1="15" y1="19" x2="14" y2="22"/></svg>';
    // Snow: white-filled cloud + dots
    if((c>=71&&c<=77)||(c>=85&&c<=86))return'<svg viewBox="0 0 24 24" fill="none" stroke="#000" stroke-width="2" stroke-linecap="round"><path d="M17.5 17H9a7 7 0 1 1 6.7-9h1.8a4.5 4.5 0 0 1 0 9z" fill="#fff"/><circle cx="8" cy="20" r="0.5" fill="#000"/><circle cx="12" cy="20" r="0.5" fill="#000"/><circle cx="16" cy="20" r="0.5" fill="#000"/></svg>';
    // Thunderstorm: white-filled cloud + lightning
    if(c>=95)return'<svg viewBox="0 0 24 24" fill="none" stroke="#000" stroke-width="2" stroke-linecap="round"><path d="M17.5 16H9a7 7 0 1 1 6.7-9h1.8a4.5 4.5 0 0 1 0 9z" fill="#fff"/><polyline points="13,17 10,21 14,21 11,25" fill="none"/></svg>';
    // Fallback: white-filled cloud
    return'<svg viewBox="0 0 24 24" fill="none" stroke="#000" stroke-width="2" stroke-linecap="round"><path d="M17.5 19H9a7 7 0 1 1 6.7-9h1.8a4.5 4.5 0 0 1 0 9z" fill="#fff"/></svg>';
  }

  // ================================================================
  // BUILD HTML
  // ================================================================

  // Mark which day column starts the week (darker separator line)
  var isWeekStart = [];
  for(var i=0;i<dates.length&&i<7;i++) isWeekStart[i] = (new Date(dates[i]).getDay() === firstDayOfWeek);

  var h='<div class="cw-wrap">';

  // --- ROW 1: Header (rain probability corner + day names) ---
  h+='<div class="cw-header-row"><div class="cw-corner">';
  if(hasWeather&&rainProb.length>0&&rainProb[0]!=null) h+='<span class="cw-corner-rain">'+Math.round(rainProb[0])+'%</span>';
  h+='</div><div class="cw-day-headers">';
  for(var i=0;i<dates.length&&i<7;i++){var di=dayInfo(dates[i]);h+='<div class="cw-day-header p--0.5 text--center'+(dates[i]===todayStr?' is-today':'')+(isWeekStart[i]?' cw-week-start':'')+'">'+di.dn+' '+di.dd+'</div>';}
  h+='</div></div>';

  // --- ROW 2: Weather charts (current temp corner + per-day mini charts) ---
  // Each day cell has 3 layers: precipitation bars, temperature line, icon+text overlay
  if (hasWeather) {
    h+='<div class="cw-weather-row"><div class="cw-corner-weather">';
    if(currentTemp!==null) h+='<span class="cw-corner-temp">'+currentTemp+'\u00B0</span>';
    h+='</div>';
    for(var i=0;i<dates.length&&i<7;i++){
      var dh=hourlyByDate[dates[i]]||[];
      h+='<div class="cw-weather-cell p--0.5'+(isWeekStart[i]?' cw-week-start':'')+'" style="flex:1;">';
      // Layer 0: Nighttime shading (gray-75 background for hours before sunrise / after sunset)
      var srHr = (daily.sunrise && daily.sunrise[i]) ? parseInt(daily.sunrise[i].substring(11,13)) : 7;
      var ssHr = (daily.sunset && daily.sunset[i]) ? parseInt(daily.sunset[i].substring(11,13)) : 20;
      h+='<div class="cw-wx-night">';
      for(var hh=0;hh<24;hh++){h+='<div'+((hh<srHr||hh>=ssHr)?' class="bg--gray-75"':'')+'></div>';}
      h+='</div>';
      // Layer 1: Precipitation probability bars (24 columns, height = probability %)
      h+='<div class="cw-wx-precip">';
      for(var hh=0;hh<24;hh++){var pp=dh[hh]?Math.round(dh[hh].p):0;h+='<div style="height:'+pp+'%"></div>';}
      h+='</div>';
      // Layer 2: Temperature line (SVG polyline, scale: 0C=bottom, 40C=top)
      h+='<svg class="cw-wx-templine" viewBox="0 0 23 40" preserveAspectRatio="none">';
      // Reference lines: vertical at noon (x=12), horizontal at 20 degrees (y=20)
      h+='<line x1="12" y1="0" x2="12" y2="40" stroke="#AAA" stroke-width="1" stroke-dasharray="1,7" vector-effect="non-scaling-stroke"/>';
      h+='<line x1="0" y1="20" x2="23" y2="20" stroke="#AAA" stroke-width="1" stroke-dasharray="1,7" vector-effect="non-scaling-stroke"/>';
      h+='<polyline points="';
      var pts='',fc=true;
      for(var hh=0;hh<24;hh++){if(dh[hh]){if(!fc)pts+=' ';pts+=hh+','+(40-Math.max(0,Math.min(40,dh[hh].t))).toFixed(1);fc=false;}}
      h+=pts+'" fill="none" stroke="#555" stroke-width="1.5" vector-effect="non-scaling-stroke"/></svg>';
      // Vertical "now" line on today's weather cell
      if(dates[i]===todayIso){var nowPctW=(nowMin/1440)*100;h+='<div class="cw-wx-now" style="left:'+nowPctW+'%"></div>';}
      // Layer 3: Weather icon (left) + min/max temp text (right)
      h+='<span class="cw-wx-text">'+wIcon(wmoCodes[i])+'<span class="cw-temps px--0.5 rounded--xsmall">'+Math.round(tempMin[i])+'\u00B0/<span class="cw-temp-max">'+Math.round(tempMax[i])+'\u00B0</span></span></span>';
      h+='</div>';
    }
    h+='</div>';
  }

  // --- ROW 3: All-day events strip (only rendered if any exist) ---
  if(hasAD){
    h+='<div class="cw-allday-row"><div class="cw-allday-label pl--1.5">ALL<br>DAY</div>';
    for(var i=0;i<dates.length&&i<7;i++){
      var ad=adByDate[dates[i]]||[];
      h+='<div class="cw-allday-cell p--0.5'+(isWeekStart[i]?' cw-week-start':'')+'" style="flex:1;">';
      for(var a=0;a<ad.length;a++){var ci=getCalIdx(ad[a].calname||ad[a].calendar_name||""),past=isPast(dates[i],1440);h+='<div class="cw-allday-evt"><div class="cw-allday-bar cw-bar-'+ci+'"></div><div class="cw-allday-text px--0.5 '+(past?'is-past':'is-future')+'">'+esc(ad[a].summary||"No title")+'</div></div>';}
      h+='</div>';
    }
    h+='</div>';
  }

  // --- ROW 4: Time grid (fills remaining height) ---
  // Left: time axis with hour labels, hourly weather, and now indicator
  h+='<div class="cw-grid-area"><div class="cw-time-axis">';
  // Hour labels (e.g. " 9:00", "10:00")
  for(var m=gMin;m<=gMax;m+=60) h+='<div class="cw-hour-label" style="top:'+((m-gMin)/rng*100)+'%;">'+fmtH(m)+'</div>';
  // Hourly weather at half-hour marks: shows temp if dry (<40%), rain% if wet (>=40%)
  // Sunrise/sunset icons shown at the half-hour mark of their respective hours
  var srMinAxis = sunrise ? (parseInt(sunrise.split(':')[0])*60+parseInt(sunrise.split(':')[1])) : -1;
  var ssMinAxis = sunset ? (parseInt(sunset.split(':')[0])*60+parseInt(sunset.split(':')[1])) : -1;
  var srHalf = srMinAxis>=0 ? Math.floor(srMinAxis/60)*60+30 : -1;
  var ssHalf = ssMinAxis>=0 ? Math.floor(ssMinAxis/60)*60+30 : -1;
  var axisSun='<svg viewBox="0 0 16 16" width="8" height="8" fill="none" stroke="#555" stroke-width="1.5" style="vertical-align:middle"><circle cx="8" cy="8" r="3"/><line x1="8" y1="2" x2="8" y2="4"/><line x1="8" y1="12" x2="8" y2="14"/><line x1="3.5" y1="3.5" x2="5" y2="5"/><line x1="11" y1="11" x2="12.5" y2="12.5"/><line x1="2" y1="8" x2="4" y2="8"/><line x1="12" y1="8" x2="14" y2="8"/><line x1="3.5" y1="12.5" x2="5" y2="11"/><line x1="11" y1="5" x2="12.5" y2="3.5"/></svg>';
  var axisMoon='<svg viewBox="0 0 16 16" width="8" height="8" fill="#555" stroke="#555" stroke-width="1" style="vertical-align:middle"><path d="M13 8a5 5 0 1 1-5-5 3.5 3.5 0 0 0 5 5z"/></svg>';
  for(var m=gMin+30;m<gMax;m+=60){var hr=Math.floor(m/60),hw=todayHourly[hr];
    var icon='';
    if(m===srHalf) icon=axisSun+' ';
    else if(m===ssHalf) icon=axisMoon+' ';
    if(hw){var wxTxt=hw.p>=40?hw.p+'%':'<b>'+hw.t+'\u00B0</b>';h+='<div class="cw-hour-weather" style="top:'+((m-gMin)/rng*100)+'%;">'+icon+wxTxt+'</div>';}
    else if(icon){h+='<div class="cw-hour-weather" style="top:'+((m-gMin)/rng*100)+'%;">'+icon+'</div>';}
  }
  // Current time indicator (bold tick line, clamped to grid range)
  var nowC=Math.max(gMin,Math.min(gMax,nowMin)),nowP=((nowC-gMin)/rng)*100;
  h+='<div class="cw-now-tick" style="top:'+nowP+'%;"></div>';
  h+='</div><div class="cw-columns">';

  // Horizontal grid lines: dashed for hours, sparse dots for half-hours
  for(var m=gMin;m<=gMax;m+=60) h+='<div class="cw-hour-line" style="top:'+((m-gMin)/rng*100)+'%;"></div>';
  for(var m=gMin+30;m<gMax;m+=60) h+='<div class="cw-half-line" style="top:'+((m-gMin)/rng*100)+'%;"></div>';

  // Day columns with positioned events
  for(var i=0;i<dates.length&&i<7;i++){
    h+='<div class="cw-day-col'+(isWeekStart[i]?' cw-week-start':'')+'">';
    var dt=tmByDate[dates[i]]||[];
    // Assign side-by-side columns for overlapping events
    layoutOverlaps(dt);
    for(var t=0;t<dt.length;t++){
      var ev=dt[t];
      // Position event block: top and height as % of the visible time range
      var topP=((ev.sm-gMin)/rng)*100,htP=((ev.em-ev.sm)/rng)*100;
      if(topP<0){htP+=topP;topP=0;} if(topP+htP>100)htP=100-topP; if(htP<2)htP=2;
      var dur=ev.em-ev.sm,ci=getCalIdx(ev.cn),past=isPast(dates[i],ev.em);
      // For overlapping events: divide width equally among columns
      var tc=ev.totalCols||1,col=ev.col||0;
      var leftP=(col/tc)*100,widP=(1/tc)*100;

      h+='<div class="cw-evt" style="top:'+topP+'%;height:'+htP+'%;left:'+leftP+'%;width:'+widP+'%;">';
      h+='<div class="cw-evt-bar cw-bar-'+ci+'"></div>';
      h+='<div class="cw-evt-body p--0.5 '+(past?'is-past':'is-future')+'">';
      h+='<div class="cw-evt-title">'+esc(ev.summary)+'</div>';
      // Show time for events 30min+, show location/description for events 60min+
      if(dur>=30) h+='<div class="cw-evt-time">'+esc(ev.start)+(ev.end?'-'+esc(ev.end):'')+'</div>';
      if(dur>=60){var det="";if(ev.loc)det+=ev.loc;if(ev.desc){if(det)det+=" - ";det+=ev.desc;}if(det)h+='<div class="cw-evt-detail">'+esc(det)+'</div>';}
      h+='</div></div>';
    }
    h+='</div>';
  }
  h+='</div></div>';

  // --- ROW 5: Legend bar (calendar names left, weather info right) ---
  var hasExtra = sunrise||sunset||uvMax!==null||aqi!==null;
  if(allCalNames.length>1||hasExtra){
    h+='<div class="cw-legend py--1 px--1.5">';
    // Calendar legend: colored swatches + names
    for(var l=0;l<allCalNames.length;l++){var idx=calNameMap[allCalNames[l]];h+='<span class="cw-legend-item"><span class="cw-legend-swatch rounded--xsmall cw-bar-'+idx+'"></span><span>'+esc(allCalNames[l])+'</span></span>';}
    h+='<span style="flex:1"></span>';
    // Weather extras: sunrise, sunset, UV index, air quality
    var extras=[];
    var sunSvg='<svg viewBox="0 0 16 16" width="10" height="10" fill="none" stroke="#555" stroke-width="1.5" style="vertical-align:middle"><circle cx="8" cy="8" r="3"/><line x1="8" y1="1" x2="8" y2="3.5"/><line x1="8" y1="12.5" x2="8" y2="15"/><line x1="3" y1="3" x2="4.8" y2="4.8"/><line x1="11.2" y1="11.2" x2="13" y2="13"/><line x1="1" y1="8" x2="3.5" y2="8"/><line x1="12.5" y1="8" x2="15" y2="8"/><line x1="3" y1="13" x2="4.8" y2="11.2"/><line x1="11.2" y1="4.8" x2="13" y2="3"/></svg>';
    var moonSvg='<svg viewBox="0 0 16 16" width="10" height="10" fill="#555" stroke="#555" stroke-width="1" style="vertical-align:middle"><path d="M13 8a5 5 0 1 1-5-5 3.5 3.5 0 0 0 5 5z"/></svg>';
    if(sunrise) extras.push(sunSvg+' '+sunrise);
    if(sunset) extras.push(moonSvg+' '+sunset);
    if(uvMax!==null) extras.push('UV:'+uvMax);
    if(aqi!==null) extras.push('AQI:'+aqi);
    if(extras.length) h+='<span class="cw-legend-extra">'+extras.join('&nbsp; &nbsp; &nbsp;')+'</span>';
    h+='</div>';
  }

  h+='</div>';
  // Append diagnostic overlay if any issues were detected (shown on top of content)
  if (diag.length > 0) { container.style.position = 'relative'; h += renderDiag(); }
  container.innerHTML=h;
});
</script>
